# Toggle mock mode — leave true for demo, set false for real integrations
MOCK_MODE=true

# ServiceNow (only used when MOCK_MODE=false)
SERVICENOW_URL=https://your-instance.service-now.com
SERVICENOW_USER=your_user
SERVICENOW_PASS=your_password

# Rundeck (only used when MOCK_MODE=false)
RUNDECK_URL=https://rundeck.ember-grid.internal
RUNDECK_TOKEN=your_token

# GitHub (only used when MOCK_MODE=false)
GITHUB_TOKEN=your_token
GITHUB_ORG=ember-grid-devops

# Ollama — always local, never external
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# RAG
CHROMA_DB_PATH=./chroma_db
KNOWLEDGE_BASE_PATH=./knowledge-base
